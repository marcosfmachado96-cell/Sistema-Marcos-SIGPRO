# ============================================================================
# Variáveis de ambiente — NUNCA versione o arquivo .env real (só este exemplo).
# Copie para .env e preencha os valores.
# ============================================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000
APP_URL_BASE=http://localhost:5173

# --- Produção (deploy) ---
# Atrás de proxy reverso (Railway/Render/Nginx): true para IP correto no rate limit.
TRUST_PROXY=false
# Servir o build do frontend pelo backend (deploy de serviço único): true em produção.
SERVE_FRONTEND=false
# Caminho do build do frontend (o Dockerfile já define). Em deploy manual: ../frontend/dist
# FRONTEND_DIST=
# CORS: só quando o frontend estiver em outra origem. Lista separada por vírgula.
# CORS_ORIGIN=https://app.seu-dominio.com

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL="postgresql://usuario:senha@localhost:5432/medicao_der_pr?schema=public"

# --- Autenticação (JWT) ---
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=8h

# --- Convites ---
CONVITE_VALIDADE_HORAS=72

# --- Seed do coordenador (administrador inicial) ---
SEED_COORDENADOR_NOME="Seu Nome"
SEED_COORDENADOR_EMAIL=seu-email@exemplo.com
SEED_COORDENADOR_SENHA=defina-uma-senha-forte

# --- E-mail (Etapa 6) — SMTP autenticado, agnóstico de provedor ---
# Configurado para Gmail. Requisitos:
#  1. Ative a verificação em duas etapas na Conta Google.
#  2. Gere uma "Senha de app" (16 caracteres) em
#     https://myaccount.google.com/apppasswords e use-a em SMTP_PASS
#     (NÃO use a senha normal da conta).
#  3. EMAIL_REMETENTE deve ser o próprio endereço Gmail (ou um alias
#     verificado em "Enviar e-mail como").
# Limites: conta Gmail comum ~500 destinatários/dia; Workspace ~2.000.
# Teste a configuração com:  npm run email:teste seu-email@exemplo.com
EMAIL_FINANCEIRO=financeiro@simemp.com.br
EMAIL_REMETENTE=seu-email@gmail.com
EMAIL_REPLY_TO=seu-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=senha-de-app-de-16-caracteres

# --- Armazenamento de arquivos (Etapa 4) — S3 ou compatível (R2, etc.) ---
# Amazon S3: deixe S3_ENDPOINT vazio e informe S3_REGION.
# Cloudflare R2/MinIO: informe S3_ENDPOINT (ex.: https://<conta>.r2.cloudflarestorage.com)
#   e use S3_REGION=auto.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Expiração das URLs assinadas de download (segundos).
DOWNLOAD_EXPIRA_SEGUNDOS=300
LINK_EMAIL_EXPIRA_SEGUNDOS=259200

# --- Upload ---
MAX_UPLOAD_MB=25

# --- Modo de armazenamento ---
# Vazio = automático (usa S3 se configurado; senão, disco local).
# 'local' força disco local — útil para TESTAR sem bucket. Não use em produção.
# 's3' força S3/R2.
STORAGE_DRIVER=
# Pasta do armazenamento local (driver 'local'). Padrão: ./uploads_local
# STORAGE_LOCAL_DIR=

# --- Analise por IA (Grupo B) ---
# Sem chave, a analise opera em modo de simulacao (para testes).
# Com a chave da Anthropic, a IA analisa o relatorio de verdade.
ANTHROPIC_API_KEY=
IA_MODELO=claude-sonnet-4-6
